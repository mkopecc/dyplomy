<Window x:Class="SystemDyplomow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SystemDyplomow.Views"
        Title="System Dyplomów" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/logo.ico"
        Background="{StaticResource SurfaceBrush}">

    <DockPanel>

        <!-- Nagłówek -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Resources/logo.png" Width="44" Height="44"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="System Dyplomów" FontSize="20" FontWeight="SemiBold"
                               Foreground="White" LineHeight="24"/>
                    <TextBlock Text="zarządzanie pracami dyplomowymi" FontSize="12"
                               Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Zakładki -->
        <TabControl Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Padding"   Value="16,8"/>
                    <Setter Property="FontSize"  Value="13"/>
                    <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabItem Header="Prace dyplomowe">
                <views:PraceView/>
            </TabItem>

            <TabItem Header="Recenzje">
                <views:RecenzjeView/>
            </TabItem>

            <TabItem Header="Obrony">
                <views:ObronyView/>
            </TabItem>

            <TabItem Header="Wydziały">
                <views:WydzialyView/>
            </TabItem>

            <TabItem Header="Kierunki">
                <views:KierunkiView/>
            </TabItem>

            <TabItem Header="Statystyki">
                <views:StatystykiView/>
            </TabItem>

            <TabItem Header="Użytkownicy">
                <views:UzytkownicyView/>
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>

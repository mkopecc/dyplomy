<UserControl x:Class="SystemDyplomow.Views.UzytkownicyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemDyplomow.ViewModels">
    <UserControl.DataContext>
        <vm:UzytkownicyViewModel/>
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filtr i przyciski -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Funkcja:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="160" ItemsSource="{Binding FunkcjeFiltr}"
                      SelectedItem="{Binding SelectedFiltr}"/>
            <Button Content="Odśwież" Command="{Binding OdswiezCommand}"
                    Style="{StaticResource BtnSecondary}" Margin="12,0,0,0"/>
            <Button Content="Usuń zaznaczonego" Command="{Binding UsunCommand}"
                    Style="{StaticResource BtnSecondary}" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Tabela użytkowników -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Uzytkownicy}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding UzytkownikId}" Width="45"/>
                <DataGridTextColumn Header="Nazwisko" Binding="{Binding Nazwisko}"     Width="130"/>
                <DataGridTextColumn Header="Imię"     Binding="{Binding Imie}"         Width="110"/>
                <DataGridTextColumn Header="Email"    Binding="{Binding Email}"         Width="*"/>
                <DataGridTextColumn Header="Telefon"  Binding="{Binding Telefon}"       Width="110"/>
                <DataGridTextColumn Header="PESEL"    Binding="{Binding Pesel}"         Width="115"/>
                <DataGridTextColumn Header="Funkcja"  Binding="{Binding Funkcja}"       Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Kierunki wybranego studenta (widoczne tylko gdy zaznaczony jest student) -->
        <GroupBox Grid.Row="2"
                  Header="{Binding Selected.PelneNazwisko, StringFormat='Kierunki studenta: {0}'}"
                  Margin="0,10,0,0"
                  Style="{StaticResource GroupBoxStyle}"
                  Visibility="{Binding IsStudentSelected,
                               Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Lista aktualnych kierunków -->
                <DataGrid Grid.Column="0"
                          ItemsSource="{Binding StudentKierunki}"
                          SelectedItem="{Binding SelectedKierunekDoUsuniecia}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          MaxHeight="130"
                          Style="{StaticResource DataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kierunek" Binding="{Binding Nazwa}"        Width="*"/>
                        <DataGridTextColumn Header="Stopień"  Binding="{Binding Stopien}"      Width="100"/>
                        <DataGridTextColumn Header="Wydział"  Binding="{Binding WydzialNazwa}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Panel przypisania / usunięcia -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Przypisz do kierunku:" Margin="0,0,0,4" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding WszystkieKierunki}"
                              SelectedItem="{Binding SelectedKierunekDoDodania}"
                              DisplayMemberPath="Nazwa"
                              Margin="0,0,0,6"/>
                    <Button Content="➕  Przypisz kierunek"
                            Command="{Binding PrzypiszKierunekCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Margin="0,0,0,10"/>
                    <Button Content="🗑  Usuń zaznaczony kierunek"
                            Command="{Binding UsunZKierunkuCommand}"
                            Style="{StaticResource BtnSecondary}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Formularz dodawania użytkownika -->
        <GroupBox Grid.Row="3" Header="Dodaj użytkownika" Margin="0,10,0,0"
                  Style="{StaticResource GroupBoxStyle}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Imię + Nazwisko -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Imię:"     Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,4,16,4"
                           Text="{Binding Imie, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Nazwisko:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="3" Margin="0,4,0,4"
                           Text="{Binding Nazwisko, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Email + Telefon -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:"    Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,4,16,4"
                           Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Telefon:"  Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="3" Margin="0,4,0,4"
                           Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- PESEL + Funkcja + przycisk -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="PESEL:"    Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,4,16,4"
                           Text="{Binding Pesel, UpdateSourceTrigger=PropertyChanged}"
                           MaxLength="11"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Funkcja:"  Margin="0,4,8,4" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal">
                    <ComboBox Width="140" Margin="0,4,12,4"
                              ItemsSource="{Binding Funkcje}"
                              SelectedItem="{Binding Funkcja}"/>
                    <Button Content="Dodaj" Command="{Binding DodajCommand}"
                            Style="{StaticResource BtnPrimary}" Margin="0,4,0,4"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>

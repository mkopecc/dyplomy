<UserControl x:Class="SystemDyplomow.Views.PraceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemDyplomow.ViewModels">
    <UserControl.DataContext>
        <vm:PraceViewModel/>
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filtr + odśwież -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="180" ItemsSource="{Binding Statusy}"
                      SelectedItem="{Binding SelectedStatus}"/>
            <Button Content="Odśwież" Command="{Binding OdswiezCommand}"
                    Style="{StaticResource BtnSecondary}" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Tabela prac -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Prace}"
                  SelectedItem="{Binding SelectedPraca}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"    Binding="{Binding PracaId}" Width="45"/>
                <DataGridTextColumn Header="Tytuł" Binding="{Binding Tytul}"    Width="*"/>

                <DataGridTextColumn Header="Student" Binding="{Binding StudentImieNazwisko}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip>
                                        <StackPanel Margin="2">
                                            <TextBlock FontWeight="Bold" FontSize="13"
                                                       Text="{Binding StudentImieNazwisko}" Margin="0,0,0,6"/>
                                            <TextBlock><Run FontWeight="SemiBold">Email: </Run><Run Text="{Binding StudentEmail}"/></TextBlock>
                                            <TextBlock><Run FontWeight="SemiBold">PESEL: </Run><Run Text="{Binding StudentPesel}"/></TextBlock>
                                            <TextBlock><Run FontWeight="SemiBold">Funkcja: </Run><Run Text="student"/></TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Promotor" Binding="{Binding PromotorImieNazwisko}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip>
                                        <StackPanel Margin="2">
                                            <TextBlock FontWeight="Bold" FontSize="13"
                                                       Text="{Binding PromotorImieNazwisko}" Margin="0,0,0,6"/>
                                            <TextBlock><Run FontWeight="SemiBold">Email: </Run><Run Text="{Binding PromotorEmail}"/></TextBlock>
                                            <TextBlock><Run FontWeight="SemiBold">PESEL: </Run><Run Text="{Binding PromotorPesel}"/></TextBlock>
                                            <TextBlock><Run FontWeight="SemiBold">Funkcja: </Run><Run Text="pracownik uczelni"/></TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Status"        Binding="{Binding Status}"                          Width="140"/>
                <DataGridTextColumn Header="Data złożenia" Binding="{Binding DataZlozenia, StringFormat=d}"    Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Zmiana statusu -->
        <GroupBox Grid.Row="2" Header="Zmień status wybranej pracy" Margin="0,12,0,0" Style="{StaticResource GroupBoxStyle}">
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="Nowy status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="160" ItemsSource="{Binding StatusyZmiany}"
                          SelectedItem="{Binding NowyStatus}"/>
                <Button Content="Zmień status" Command="{Binding ZmienStatusCommand}"
                        Style="{StaticResource BtnPrimary}" Margin="12,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Formularz nowej pracy -->
        <GroupBox Grid.Row="3" Header="Dodaj nową pracę" Margin="0,8,0,0" Style="{StaticResource GroupBoxStyle}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Student:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,4,16,4"
                           ItemsSource="{Binding Studenci}" DisplayMemberPath="PelneNazwisko"
                           SelectedItem="{Binding SelectedStudent}"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Promotor:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="0" Grid.Column="3" Margin="0,4,0,4"
                           ItemsSource="{Binding Promotorzy}" DisplayMemberPath="PelneNazwisko"
                           SelectedItem="{Binding SelectedPromotor}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tytuł:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,4,0,4"
                           Text="{Binding Tytul, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Data złożenia:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="2" Grid.Column="1" Margin="0,4,16,4"
                            SelectedDate="{Binding DataZlozenia}"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Plik pracy:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal">
                    <TextBox Width="160" Margin="0,4,12,4"
                             Text="{Binding PlikPracy, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Opcjonalna nazwa lub ścieżka pliku (maks. 50 znaków)"/>
                    <Button Content="Dodaj pracę" Command="{Binding DodajPraceCommand}"
                            Style="{StaticResource BtnPrimary}" Margin="0,4,0,4"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>

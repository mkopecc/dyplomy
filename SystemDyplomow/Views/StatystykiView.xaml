<UserControl x:Class="SystemDyplomow.Views.StatystykiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemDyplomow.ViewModels">
    <UserControl.DataContext>
        <vm:StatystykiViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style x:Key="TileStyle" TargetType="Border">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="MinWidth" Value="150"/>
        </Style>
        <Style x:Key="TileValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TileLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#BBDEFB"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Kafelki ogólne -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,16">
            <Border Style="{StaticResource TileStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding LiczbaPrac}" Style="{StaticResource TileValueStyle}"/>
                    <TextBlock Text="Prace dyplomowe" Style="{StaticResource TileLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileStyle}" Background="#388E3C">
                <StackPanel>
                    <TextBlock Text="{Binding LiczbaObron}" Style="{StaticResource TileValueStyle}"/>
                    <TextBlock Text="Obrony" Style="{StaticResource TileLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileStyle}" Background="#F57C00">
                <StackPanel>
                    <TextBlock Text="{Binding LiczbaRecenzji}" Style="{StaticResource TileValueStyle}"/>
                    <TextBlock Text="Recenzje" Style="{StaticResource TileLabelStyle}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Nagłówek tabeli -->
        <TextBlock Grid.Row="1" Text="Statystyki promotorów" FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,8" Foreground="#1565C0"/>

        <!-- Tabela statystyk promotorów -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Statystyki}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Promotor"        Binding="{Binding PromotorImieNazwisko}" Width="*"/>
                <DataGridTextColumn Header="Liczba prac"     Binding="{Binding LiczbaPrac}"    Width="110"/>
                <DataGridTextColumn Header="Średnia ocena"   Binding="{Binding SredniaOcena, StringFormat=F2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

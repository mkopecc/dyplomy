<UserControl x:Class="SystemDyplomow.Views.KierunkiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemDyplomow.ViewModels">
    <UserControl.DataContext>
        <vm:KierunkiViewModel/>
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pasek narzędzi -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Odśwież"         Command="{Binding OdswiezCommand}" Style="{StaticResource BtnSecondary}"/>
            <Button Content="Usuń zaznaczony" Command="{Binding UsunCommand}"    Style="{StaticResource BtnSecondary}" Margin="10,0,0,0"/>
            <Button Content="Anuluj edycję"   Command="{Binding AnulujCommand}"  Style="{StaticResource BtnSecondary}" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Tabela kierunków -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Kierunki}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding KierunekId}"   Width="45"/>
                <DataGridTextColumn Header="Kierunek" Binding="{Binding Nazwa}"         Width="*"/>
                <DataGridTextColumn Header="Stopień"  Binding="{Binding Stopien}"       Width="130"/>
                <DataGridTextColumn Header="Wydział"  Binding="{Binding WydzialNazwa}"  Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Formularz dodawania / edycji -->
        <GroupBox Grid.Row="2" Header="Kierunek" Margin="0,10,0,0"
                  Style="{StaticResource GroupBoxStyle}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Nazwa kierunku:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Column="1" Margin="0,4,16,4"
                           Text="{Binding Nazwa, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="2" Text="Stopień:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Column="3" Margin="0,4,16,4"
                           ItemsSource="{Binding Stopnie}"
                           SelectedItem="{Binding Stopien}"/>

                <TextBlock Grid.Column="4" Text="Wydział:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Column="5" Margin="0,4,12,4"
                           ItemsSource="{Binding Wydzialy}"
                           SelectedItem="{Binding SelectedWydzial}"
                           DisplayMemberPath="Nazwa"/>

                <Button Grid.Column="6" Content="{Binding ButtonLabel}"
                        Command="{Binding ZapiszCommand}"
                        Style="{StaticResource BtnPrimary}" Margin="0,4,0,4"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>

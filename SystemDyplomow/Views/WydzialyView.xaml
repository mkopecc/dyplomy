<UserControl x:Class="SystemDyplomow.Views.WydzialyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemDyplomow.ViewModels">
    <UserControl.DataContext>
        <vm:WydzialyViewModel/>
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pasek narzędzi -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Odśwież"          Command="{Binding OdswiezCommand}" Style="{StaticResource BtnSecondary}"/>
            <Button Content="Usuń zaznaczony"  Command="{Binding UsunCommand}"    Style="{StaticResource BtnSecondary}" Margin="10,0,0,0"/>
            <Button Content="Anuluj edycję"    Command="{Binding AnulujCommand}"  Style="{StaticResource BtnSecondary}" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Tabela wydziałów -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Wydzialy}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"      Binding="{Binding WydzialId}"           Width="45"/>
                <DataGridTextColumn Header="Wydział" Binding="{Binding Nazwa}"                Width="*"/>
                <DataGridTextColumn Header="Dziekan" Binding="{Binding DziekanImieNazwisko}"  Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding DziekanEmail}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Formularz dodawania / edycji -->
        <GroupBox Grid.Row="2" Header="Wydział" Margin="0,10,0,0"
                  Style="{StaticResource GroupBoxStyle}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Nazwa wydziału:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <TextBox   Grid.Column="1" Margin="0,4,16,4"
                           Text="{Binding Nazwa, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="2" Text="Dziekan:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Column="3" Margin="0,4,12,4"
                           ItemsSource="{Binding Pracownicy}"
                           SelectedItem="{Binding SelectedDziekan}"
                           DisplayMemberPath="PelneNazwisko"/>

                <Button Grid.Column="4" Content="{Binding ButtonLabel}"
                        Command="{Binding ZapiszCommand}"
                        Style="{StaticResource BtnPrimary}" Margin="0,4,8,4"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>

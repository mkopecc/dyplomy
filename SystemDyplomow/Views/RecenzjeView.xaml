<UserControl x:Class="SystemDyplomow.Views.RecenzjeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemDyplomow.ViewModels">
    <UserControl.DataContext>
        <vm:RecenzjeViewModel/>
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Lista recenzji -->
        <DataGrid Grid.Row="0" ItemsSource="{Binding Recenzje}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"         Binding="{Binding RecenzjaId}"     Width="45"/>
                <DataGridTextColumn Header="Praca"      Binding="{Binding TytulPracy}"      Width="*"/>
                <DataGridTextColumn Header="Recenzent" Binding="{Binding RecenzentImieNazwisko}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip>
                                        <StackPanel Margin="2">
                                            <TextBlock FontWeight="Bold" FontSize="13"
                                                       Text="{Binding RecenzentImieNazwisko}" Margin="0,0,0,6"/>
                                            <TextBlock><Run FontWeight="SemiBold">Email: </Run><Run Text="{Binding RecenzentEmail}"/></TextBlock>
                                            <TextBlock><Run FontWeight="SemiBold">PESEL: </Run><Run Text="{Binding RecenzentPesel}"/></TextBlock>
                                            <TextBlock><Run FontWeight="SemiBold">Funkcja: </Run><Run Text="pracownik uczelni"/></TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ocena"      Binding="{Binding Ocena}"           Width="70"/>
                <DataGridTextColumn Header="Data"       Binding="{Binding DataWystawienia, StringFormat=d}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Formularz -->
        <GroupBox Grid.Row="1" Header="Dodaj recenzję" Margin="0,10,0,0" Style="{StaticResource GroupBoxStyle}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Ostrzeżenie o duplikacie (wiersz 0) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="{Binding DuplikatInfo}"
                           Foreground="#C62828" FontWeight="SemiBold" FontSize="12"
                           Margin="0,2,0,4"
                           Visibility="{Binding IsDuplikat, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Praca + Recenzent (wiersz 1) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Praca:"     Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,4,16,4"
                           ItemsSource="{Binding Prace}" DisplayMemberPath="Tytul"
                           SelectedItem="{Binding SelectedPraca}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Recenzent:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="1" Grid.Column="3" Margin="0,4,0,4"
                           ItemsSource="{Binding Recenzenci}" DisplayMemberPath="PelneNazwisko"
                           SelectedItem="{Binding SelectedRecenzent}"/>

                <!-- Treść recenzji (wiersz 2) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Treść:" Margin="0,4,8,4" VerticalAlignment="Top"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,4,0,4"
                           Text="{Binding Tresc, UpdateSourceTrigger=PropertyChanged}"
                           AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                           ToolTip="Opcjonalna treść recenzji"/>

                <!-- Ocena + Data (wiersz 3) -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ocena:" Margin="0,4,8,4" VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="3" Grid.Column="1" Margin="0,4,16,4"
                           ItemsSource="{Binding DostepneOceny}" SelectedItem="{Binding Ocena}"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Data:"  Margin="0,4,8,4" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="3" Grid.Column="3" Orientation="Horizontal">
                    <DatePicker Margin="0,4,12,4" SelectedDate="{Binding DataWystawienia}"/>
                    <Button Content="Dodaj recenzję" Command="{Binding DodajCommand}"
                            Style="{StaticResource BtnPrimary}" Margin="0,4,0,4"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
